{
    "label" : "lock",
    "action" : "sh -c \"~/.config/hypr/scripts/power-menu.sh --lock\"",
    "text" : "Lock",
    "keybind" : "l"
}
{
    "label" : "suspend",
    "action" : "systemctl suspend",
    "text" : "Suspend",
    "keybind" : "s"
}
{
    "label" : "logout",
    "action" : "hyprshutdown",
    "text" : "Log Out",
    "keybind" : "e"
}
{
    "label" : "reboot",
    "action" : "hyprshutdown -t 'Reiniciando...' --post-cmd 'reboot'",
    "text" : "Reboot",
    "keybind" : "r"
}
{
    "label" : "shutdown",
    "action" : "hyprshutdown -t 'Desligando...' --post-cmd 'shutdown -P 0'",
    "text" : "Shut Down",
    "keybind" : "s"
}
